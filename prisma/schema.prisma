generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model usuarios {
  usuario_id                BigInt                      @id @default(autoincrement())
  nombre                    String
  email                     String
  password_hash             String
  moneda_base               String                      @default("DOP")
  meta_financiera           String?
  meta_monto                Decimal?                    @db.Decimal(15, 2)
  meta_fecha                DateTime?                   @db.Date
  creado_en                 DateTime                    @default(now()) @db.Timestamptz(6)
  actualizado_en            DateTime                    @default(now()) @updatedAt @db.Timestamptz(6)
  activos                   activos[]
  alertas                   alertas[]
  categorias                categorias[]
  invitaciones_enviadas     espacio_invitaciones[]
  espacio_miembros          espacio_miembros[]
  espacios_creados          espacios_compartidos[]      @relation("creador")
  presupuestos              presupuestos[]
  suscripciones             suscripciones?
  transacciones             transacciones[]
  transacciones_recurrentes transacciones_recurrentes[]
}

model suscripciones {
  suscripcion_id BigInt             @id @default(autoincrement())
  usuario_id     BigInt             @unique(map: "suscripciones_usuario_id_idx")
  estado         estado_suscripcion @default(prueba)
  plan           String             @default("mensual")
  precio_usd     Decimal            @default(5.00) @db.Decimal(6, 2)
  revenuecat_id  String?            @unique
  trial_inicio   DateTime           @default(now()) @db.Timestamptz(6)
  trial_fin      DateTime           @default(dbgenerated("(now() + '5 days'::interval)")) @db.Timestamptz(6)
  periodo_inicio DateTime?          @db.Timestamptz(6)
  periodo_fin    DateTime?          @db.Timestamptz(6)
  cancelado_en   DateTime?          @db.Timestamptz(6)
  creado_en      DateTime           @default(now()) @db.Timestamptz(6)
  actualizado_en DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  usuario        usuarios           @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([estado])
  @@index([periodo_fin])
}

model activos {
  activo_id                 BigInt                      @id @default(autoincrement())
  usuario_id                BigInt
  nombre                    String
  tipo                      tipo_wallet
  institucion_nombre        String?
  moneda                    String                      @default("DOP")
  valor_actual              Decimal                     @default(0.00) @db.Decimal(15, 2)
  ticker_simbolo            String?
  creado_en                 DateTime                    @default(now()) @db.Timestamptz(6)
  actualizado_en            DateTime                    @default(now()) @updatedAt @db.Timestamptz(6)
  espacio_id                BigInt?
  color_hex                 String                      @default("#4F46E5")
  icono                     String                      @default("landmark")
  espacio                   espacios_compartidos?       @relation(fields: [espacio_id], references: [espacio_id], onUpdate: NoAction)
  usuario                   usuarios                    @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  transacciones_destino     transacciones[]             @relation("activo_destino")
  transacciones_origen      transacciones[]             @relation("activo_origen")
  transacciones_recurrentes transacciones_recurrentes[]

  @@index([usuario_id])
  @@index([usuario_id, tipo])
}

model categorias {
  categoria_id              BigInt                      @id @default(autoincrement())
  usuario_id                BigInt?
  categoria_padre_id        BigInt?
  nombre                    String
  tipo                      tipo_transaccion            @default(gasto)
  icono                     String                      @default("circle")
  color_hex                 String                      @default("#6B7280")
  es_sistema                Boolean                     @default(false)
  creado_en                 DateTime                    @default(now()) @db.Timestamptz(6)
  slug                      String?
  usuario                   usuarios?                   @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  padre                     categorias?                 @relation("categoria_jerarquia", fields: [categoria_padre_id], references: [categoria_id], onUpdate: NoAction)
  hijos                     categorias[]                @relation("categoria_jerarquia")
  presupuesto_categorias    presupuesto_categorias[]
  transacciones             transacciones[]
  transacciones_recurrentes transacciones_recurrentes[]

  @@unique([usuario_id, nombre, tipo])
  @@index([usuario_id])
}

model transacciones {
  transaccion_id         BigInt                @id @default(autoincrement())
  usuario_id             BigInt
  presupuesto_id         BigInt?
  activo_id              BigInt?
  activo_destino_id      BigInt?
  tipo                   tipo_transaccion
  monto                  Decimal               @db.Decimal(15, 2)
  moneda                 String                @default("DOP")
  categoria_id           BigInt?
  descripcion            String?
  fecha                  DateTime              @default(dbgenerated("CURRENT_DATE")) @db.Date
  origen                 String                @default("app")
  creado_en              DateTime              @default(now()) @db.Timestamptz(6)
  actualizado_en         DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  espacio_id             BigInt?
  nota                   String?
  activo_destino         activos?              @relation("activo_destino", fields: [activo_destino_id], references: [activo_id], onUpdate: NoAction)
  activo                 activos?              @relation("activo_origen", fields: [activo_id], references: [activo_id], onUpdate: NoAction)
  categoria              categorias?           @relation(fields: [categoria_id], references: [categoria_id], onUpdate: NoAction)
  espacio                espacios_compartidos? @relation(fields: [espacio_id], references: [espacio_id], onUpdate: NoAction)
  presupuesto            presupuestos?         @relation(fields: [presupuesto_id], references: [presupuesto_id], onUpdate: NoAction)
  usuario                usuarios              @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([activo_destino_id])
  @@index([activo_id])
  @@index([categoria_id])
  @@index([presupuesto_id])
  @@index([descripcion(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([usuario_id, fecha(sort: Desc)])
  @@index([usuario_id, tipo, fecha(sort: Desc)])
}

model alertas {
  alerta_id   BigInt                @id @default(autoincrement())
  usuario_id  BigInt
  tipo        String
  titulo      String
  cuerpo      String
  datos_extra Json?                 @default("{}")
  fue_leida   Boolean               @default(false)
  fue_enviada Boolean               @default(false)
  creado_en   DateTime              @default(now()) @db.Timestamptz(6)
  espacio_id  BigInt?
  espacio     espacios_compartidos? @relation(fields: [espacio_id], references: [espacio_id], onDelete: Cascade, onUpdate: NoAction)
  usuario     usuarios              @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id, creado_en(sort: Desc)])
}

model espacios_compartidos {
  espacio_id     BigInt                 @id @default(autoincrement())
  nombre         String
  descripcion    String?
  creado_por     BigInt
  creado_en      DateTime               @default(now()) @db.Timestamptz(6)
  actualizado_en DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  activos        activos[]
  alertas        alertas[]
  invitaciones   espacio_invitaciones[]
  miembros       espacio_miembros[]
  creador        usuarios               @relation("creador", fields: [creado_por], references: [usuario_id], onUpdate: NoAction)
  presupuestos   presupuestos[]
  transacciones  transacciones[]

  @@index([creado_por])
}

model espacio_miembros {
  espacio_id BigInt
  usuario_id BigInt
  rol        String               @default("miembro")
  unido_en   DateTime             @default(now()) @db.Timestamptz(6)
  espacio    espacios_compartidos @relation(fields: [espacio_id], references: [espacio_id], onDelete: Cascade, onUpdate: NoAction)
  usuario    usuarios             @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([espacio_id, usuario_id])
  @@index([usuario_id])
}

model espacio_invitaciones {
  invitacion_id  BigInt               @id @default(autoincrement())
  espacio_id     BigInt
  invitado_por   BigInt
  email_invitado String
  token          String               @unique @default(dbgenerated("encode(gen_random_bytes(32), 'hex'::text)"))
  estado         String               @default("pendiente")
  expira_en      DateTime             @default(dbgenerated("(now() + '48:00:00'::interval)")) @db.Timestamptz(6)
  creado_en      DateTime             @default(now()) @db.Timestamptz(6)
  espacio        espacios_compartidos @relation(fields: [espacio_id], references: [espacio_id], onDelete: Cascade, onUpdate: NoAction)
  invitador      usuarios             @relation(fields: [invitado_por], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email_invitado, estado])
  @@index([espacio_id, estado])
  @@index([token])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model presupuesto_categorias {
  presupuesto_id BigInt
  categoria_id   BigInt
  limite         Decimal      @db.Decimal
  categorias     categorias   @relation(fields: [categoria_id], references: [categoria_id], onDelete: NoAction, onUpdate: NoAction)
  presupuestos   presupuestos @relation(fields: [presupuesto_id], references: [presupuesto_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([presupuesto_id, categoria_id])
}

model presupuesto_ingresos {
  presupuesto_id  BigInt
  categoria_id    BigInt
  monto_planeado  Decimal      @db.Decimal
  creado_en       DateTime     @default(now()) @db.Timestamptz(6)
  categorias      categorias   @relation(fields: [categoria_id], references: [categoria_id], onDelete: NoAction, onUpdate: NoAction)
  presupuestos    presupuestos @relation(fields: [presupuesto_id], references: [presupuesto_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([presupuesto_id, categoria_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model presupuestos {
  presupuesto_id         BigInt                   @id @default(autoincrement())
  usuario_id             BigInt
  espacio_id             BigInt?
  nombre                 String
  periodo                String
  dia_inicio             Int                      @default(1)
  ingresos               Decimal                  @default(0) @db.Decimal
  ahorro_objetivo        Decimal                  @default(0) @db.Decimal
  activo                 Boolean                  @default(true)
  creado_en              DateTime                 @default(now()) @db.Timestamptz(6)
  actualizado_en         DateTime                 @default(now()) @db.Timestamptz(6)
  presupuesto_categorias presupuesto_categorias[]
  presupuesto_ingresos   presupuesto_ingresos[]
  transacciones_recurrentes transacciones_recurrentes[]
  transacciones          transacciones[]
  espacios_compartidos   espacios_compartidos?    @relation(fields: [espacio_id], references: [espacio_id], onDelete: NoAction, onUpdate: NoAction)
  usuarios               usuarios                 @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transacciones_recurrentes {
  recurrente_id     BigInt           @id @default(autoincrement())
  usuario_id        BigInt
  presupuesto_id    BigInt?
  activo_id         BigInt?
  categoria_id      BigInt?
  tipo              tipo_transaccion
  monto             Decimal          @db.Decimal
  moneda            String           @default("DOP")
  descripcion       String?
  frecuencia        String
  dia_ejecucion     Int
  activo            Boolean          @default(true)
  proxima_ejecucion DateTime?        @db.Date
  creado_en         DateTime         @default(now()) @db.Timestamptz(6)
  actualizado_en    DateTime         @default(now()) @db.Timestamptz(6)
  nota              String?
  activos           activos?         @relation(fields: [activo_id], references: [activo_id], onDelete: NoAction, onUpdate: NoAction)
  categorias        categorias?      @relation(fields: [categoria_id], references: [categoria_id], onDelete: NoAction, onUpdate: NoAction)
  presupuestos      presupuestos?    @relation(fields: [presupuesto_id], references: [presupuesto_id], onDelete: NoAction, onUpdate: NoAction)
  usuarios          usuarios         @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)
}

enum tipo_wallet {
  gastos
  cuentas
  deudas
}

enum tipo_transaccion {
  ingreso
  gasto
  transferencia
}

enum estado_suscripcion {
  prueba
  activa
  vencida
  cancelada
}
